<?xml version="1.0" encoding="utf-8"?>
<!--
    Face details (eyes + smile) of the cartoon outfit figure. Renders on top
    of the skin and garment layers. Intentionally NOT tinted at render time:
    eyes are black regardless of skin/garment colour selections. Add hair,
    glasses, etc. as separate fixed-colour layers when those features are
    introduced.

    See ic_person_skin.xml for shared coordinate-system notes.
-->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="96dp"
    android:height="96dp"
    android:viewportWidth="96"
    android:viewportHeight="96">
    <!-- Left eye -->
    <path android:fillColor="#1B1C1F"
        android:pathData="M44,17 m-1.5,0 a1.5,1.5 0 1,0 3,0 a1.5,1.5 0 1,0 -3,0 z" />
    <!-- Right eye -->
    <path android:fillColor="#1B1C1F"
        android:pathData="M52,17 m-1.5,0 a1.5,1.5 0 1,0 3,0 a1.5,1.5 0 1,0 -3,0 z" />
    <!-- Smile -->
    <path android:strokeColor="#1B1C1F"
        android:strokeWidth="1.5"
        android:strokeLineCap="round"
        android:fillColor="#00000000"
        android:pathData="M44,22 Q48,25 52,22" />
</vector>
