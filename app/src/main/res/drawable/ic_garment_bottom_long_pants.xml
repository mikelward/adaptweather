<?xml version="1.0" encoding="utf-8"?>
<!--
    Long-pants overlay for the cartoon outfit figure. Covers hips down to
    the ankles, leaving only the feet visible from the skin layer.

    See ic_person_skin.xml for shared coordinate-system notes.
-->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="96dp"
    android:height="96dp"
    android:viewportWidth="96"
    android:viewportHeight="96">
    <!-- Waistband -->
    <path android:fillColor="#FFFFFF"
        android:pathData="M32,60 h32 v4 h-32 z" />
    <!-- Left full leg -->
    <path android:fillColor="#FFFFFF"
        android:pathData="M36,60 h10 v26 h-10 z" />
    <!-- Right full leg -->
    <path android:fillColor="#FFFFFF"
        android:pathData="M50,60 h10 v26 h-10 z" />
</vector>
