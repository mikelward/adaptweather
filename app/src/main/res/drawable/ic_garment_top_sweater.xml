<?xml version="1.0" encoding="utf-8"?>
<!--
    Sweater overlay for the cartoon outfit figure. Long sleeves down to the
    wrists and a turtleneck collar. Distinguishable from the t-shirt at a
    glance even at the same colour, because of the different sleeve length
    and collar.

    See ic_person_skin.xml for shared coordinate-system notes.
-->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="96dp"
    android:height="96dp"
    android:viewportWidth="96"
    android:viewportHeight="96">
    <!-- Turtleneck (covers neck, sits above the body) -->
    <path android:fillColor="#FFFFFF"
        android:pathData="M44,27 h8 v6 h-8 z" />
    <!-- Body -->
    <path android:fillColor="#FFFFFF"
        android:pathData="M30,32 h36 v28 h-36 z" />
    <!-- Left long sleeve to wrist -->
    <path android:fillColor="#FFFFFF"
        android:pathData="M22,33 h8 v28 h-8 z" />
    <!-- Right long sleeve to wrist -->
    <path android:fillColor="#FFFFFF"
        android:pathData="M66,33 h8 v28 h-8 z" />
</vector>
