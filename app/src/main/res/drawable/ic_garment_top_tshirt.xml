<?xml version="1.0" encoding="utf-8"?>
<!--
    T-shirt overlay for the cartoon outfit figure. Covers the torso and the
    upper third of each arm (short sleeves), leaving forearms and hands
    visible underneath. Single-fill silhouette so a ColorFilter.tint() at
    render time paints the whole shirt one colour.

    See ic_person_skin.xml for shared coordinate-system notes.

    TODO(customization): when garment styles become user-selectable (striped
    tee, henley, etc.), add sibling drawables and switch by appearance.style
    rather than mutating this one.
-->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="96dp"
    android:height="96dp"
    android:viewportWidth="96"
    android:viewportHeight="96">
    <!-- Body -->
    <path android:fillColor="#FFFFFF"
        android:pathData="M30,32 h36 v24 h-36 z" />
    <!-- Left short sleeve -->
    <path android:fillColor="#FFFFFF"
        android:pathData="M22,33 h8 v10 h-8 z" />
    <!-- Right short sleeve -->
    <path android:fillColor="#FFFFFF"
        android:pathData="M66,33 h8 v10 h-8 z" />
</vector>
