<?xml version="1.0" encoding="utf-8"?>
<!--
    Warning triangle with exclamation-mark cutout. Used as the small icon for
    SEVERE / EXTREME weather alert notifications. Silhouette style: white-on-transparent
    so the system applies the channel accent colour at runtime (matching how the other
    notification icons are rendered). The even-odd fill rule cuts the exclamation mark
    out of the white triangle, giving the correct visual at any tint colour.
-->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="24dp"
    android:height="24dp"
    android:viewportWidth="24"
    android:viewportHeight="24">
    <path
        android:fillColor="#FFFFFF"
        android:fillType="evenOdd"
        android:pathData="M12,2 L1,21 L23,21 Z M13,16 H11 V18 H13 Z M13,10 H11 V15 H13 Z" />
</vector>
