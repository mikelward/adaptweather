<?xml version="1.0" encoding="utf-8"?>
<!--
    Glanceable T-shirt icon for the Today screen's "What to wear" card.
    Flat-color silhouette in the GNOME Adwaita / Material spirit: bright fill,
    darker outline, recognisable at a glance even at 64dp. Colours are fixed
    (rather than themed) so the outfit row reads like an emoji row in either
    light or dark mode.
-->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="96dp"
    android:height="96dp"
    android:viewportWidth="96"
    android:viewportHeight="96">
    <path
        android:fillColor="#4FC3F7"
        android:strokeColor="#01579B"
        android:strokeWidth="2.5"
        android:strokeLineJoin="round"
        android:strokeLineCap="round"
        android:pathData="M38,16 L42,24 L48,26 L54,24 L58,16 L84,32 L76,46 L68,42 L68,84 L28,84 L28,42 L20,46 L12,32 Z" />
    <path
        android:strokeColor="#01579B"
        android:strokeWidth="1.5"
        android:strokeLineCap="round"
        android:pathData="M42,24 Q48,30 54,24" />
</vector>
