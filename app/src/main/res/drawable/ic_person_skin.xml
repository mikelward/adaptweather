<?xml version="1.0" encoding="utf-8"?>
<!--
    Skin layer of the cartoon outfit figure: head, neck, torso, arms, hands,
    legs, feet — everything that would be visible if the figure were unclothed.
    Drawn as flat white shapes so a single ColorFilter.tint() at render time
    paints the whole silhouette one tone. Garment layers are stacked on top
    and cover the relevant areas.

    Coordinate system is shared with the other ic_person_*.xml and ic_garment_*.xml
    files in this directory: 96 × 96 viewport with the figure centred horizontally,
    head at top, feet at bottom. Don't change one drawable's viewport without
    updating the rest — they're stacked in a Box at render time and the geometry
    has to line up exactly.

    TODO(customization): once skin tone is user-selectable, the renderer reads
    the selected tone from SettingsRepository and passes it as the tint colour;
    no change to this drawable is needed.
-->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="96dp"
    android:height="96dp"
    android:viewportWidth="96"
    android:viewportHeight="96">
    <!-- Head -->
    <path android:fillColor="#FFFFFF"
        android:pathData="M48,18 m-10,0 a10,10 0 1,0 20,0 a10,10 0 1,0 -20,0 z" />
    <!-- Neck -->
    <path android:fillColor="#FFFFFF"
        android:pathData="M44,27 h8 v5 h-8 z" />
    <!-- Torso -->
    <path android:fillColor="#FFFFFF"
        android:pathData="M30,32 h36 v28 h-36 z" />
    <!-- Left arm -->
    <path android:fillColor="#FFFFFF"
        android:pathData="M22,33 h8 v28 h-8 z" />
    <!-- Right arm -->
    <path android:fillColor="#FFFFFF"
        android:pathData="M66,33 h8 v28 h-8 z" />
    <!-- Left hand -->
    <path android:fillColor="#FFFFFF"
        android:pathData="M26,65 m-4,0 a4,4 0 1,0 8,0 a4,4 0 1,0 -8,0 z" />
    <!-- Right hand -->
    <path android:fillColor="#FFFFFF"
        android:pathData="M70,65 m-4,0 a4,4 0 1,0 8,0 a4,4 0 1,0 -8,0 z" />
    <!-- Left leg -->
    <path android:fillColor="#FFFFFF"
        android:pathData="M36,60 h10 v26 h-10 z" />
    <!-- Right leg -->
    <path android:fillColor="#FFFFFF"
        android:pathData="M50,60 h10 v26 h-10 z" />
    <!-- Left foot -->
    <path android:fillColor="#FFFFFF"
        android:pathData="M32,86 h16 v4 h-16 z" />
    <!-- Right foot -->
    <path android:fillColor="#FFFFFF"
        android:pathData="M48,86 h16 v4 h-16 z" />
</vector>
