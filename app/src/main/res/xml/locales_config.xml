<?xml version="1.0" encoding="utf-8"?>
<!--
    Declares the locales supported by ClothesCast, mirroring the values-xx/
    resource directories. Required on Android 13+ (API 33+): without this
    declaration, createConfigurationContext() does not reliably apply a
    non-default locale override — the system can fall back to the device
    locale instead of the requested one, which breaks InsightFormatter when
    the user picks a Region whose language differs from their device locale
    (e.g. device=en-GB, Region=DE_AT → prose renders in English).

    Note: this list uses canonical BCP-47 language tags (id, he), while the
    matching Android resource directories still use the legacy ISO-639-1
    codes the framework froze in 1989 — values-in/ for Indonesian and
    values-iw/ for Hebrew. The runtime resource resolver maps the canonical
    tag here to the legacy directory automatically.

    This file also enables per-app language preferences in system Settings
    on Android 13+ (users can override the app's display language
    independently of the system locale).
-->
<locale-config xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- English — default values/ directory -->
    <locale android:name="en"/>
    <locale android:name="en-AU"/>
    <locale android:name="en-CA"/>
    <locale android:name="en-GB"/>
    <locale android:name="en-ZA"/>

    <!-- German variants -->
    <locale android:name="de"/>
    <locale android:name="de-AT"/>
    <locale android:name="de-CH"/>

    <!-- Other supported locales (alphabetical by tag) -->
    <locale android:name="am"/>
    <locale android:name="ar"/>
    <locale android:name="bg"/>
    <locale android:name="bn"/>
    <locale android:name="ca"/>
    <locale android:name="cs"/>
    <locale android:name="da"/>
    <locale android:name="el"/>
    <locale android:name="es"/>
    <locale android:name="es-MX"/>
    <locale android:name="et"/>
    <locale android:name="fa"/>
    <locale android:name="fi"/>
    <locale android:name="fil"/>
    <locale android:name="fr"/>
    <locale android:name="fr-CA"/>
    <locale android:name="he"/>
    <locale android:name="hi"/>
    <locale android:name="hr"/>
    <locale android:name="hu"/>
    <locale android:name="id"/>
    <locale android:name="it"/>
    <locale android:name="ja"/>
    <locale android:name="ko"/>
    <locale android:name="lt"/>
    <locale android:name="lv"/>
    <locale android:name="ms"/>
    <locale android:name="nb"/>
    <locale android:name="nl"/>
    <locale android:name="pl"/>
    <locale android:name="pt-BR"/>
    <locale android:name="pt-PT"/>
    <locale android:name="ro"/>
    <locale android:name="ru"/>
    <locale android:name="sk"/>
    <locale android:name="sl"/>
    <locale android:name="sr-Latn"/>
    <locale android:name="sv"/>
    <locale android:name="sw"/>
    <locale android:name="th"/>
    <locale android:name="tr"/>
    <locale android:name="uk"/>
    <locale android:name="vi"/>
    <locale android:name="zh-CN"/>
    <locale android:name="zh-TW"/>
</locale-config>
